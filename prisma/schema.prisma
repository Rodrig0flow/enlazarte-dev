generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String   @default("web-basic")
  message   String?
  budget    String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  services    String[]
  link        String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Service {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String
  price       Int?
  features    String[]
  featured    Boolean @default(false)
  order       Int     @default(0)
}
